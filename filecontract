*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Tajawal',Arial,sans-serif;background:#f0f4f8;color:#1a1a2e;direction:rtl}

.nav{position:fixed;top:0;width:100%;background:#1a1a2e;color:#fff;z-index:999;

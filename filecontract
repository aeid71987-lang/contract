.rbadge{display:inline-block;padding:4px 14px;border-radius:20px;color:#fff;font-weight:700;font-size:0.85rem}

.cr{display:grid;grid-template-columns:1fr 1fr;gap:20px;padding:0 32px 28px}
.cc{background:#f8f9fa;border-radius:14px;padding:20px;text-align:center}

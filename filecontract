.stw{padding:0 32px 28px}
table.stbl{width:100%;border-collapse:collapse;font-size:0.9rem}
table.stbl thead tr{background:#1a1a2e;color:#fff}
table.stbl th{padding:12px 16px;text-align:center;font-weight:600}
table.stbl td{padding:11px 16px;border-bottom:1px solid #eee;text-align:center}

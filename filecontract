.nav-btn:hover,.nav-btn.active{background:#c0392b;border-color:#c0392b}

.page{max-width:1180px;margin:80px auto 40px;background:#fff;border-radius:16px;
  overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.12);display:none}
.page.active{display:block}

.page-header{display:flex;align-items:center;gap:20px;padding:24px 32px;background:#fff;border-bottom:1px solid #e8ecf0}
.header-logo img{height:70px;object-fit:contain}
.header-title{flex:1;text-align:center}
.main-title{font-size:1.6rem;font-weight:800;color:#1a1a2e;line-height:1.3}
.sub-title{font-size:1rem;color:#c0392b;font-weight:700;margin-top:4px}
.report-date{font-size:0.85rem;color:#7f8c8d;margin-top:4px}
.header-meta{text-align:center;background:#f8f9fa;border-radius:10px;padding:10px 18px}
.meta-label{font-size:0.75rem;color:#7f8c8d}
.meta-value{font-size:0.95rem;font-weight:700;color:#1a1a2e}

.summary-hero{background:linear-gradient(135deg,#1a1a2e 0%,#2c3e50 50%,#c0392b 100%);padding:40px 32px;color:#fff;text-align:center}
.summary-hero .hero-greeting{font-size:0.9rem;color:#e8d5a3;letter-spacing:2px;margin-bottom:8px}
.summary-hero .hero-main{font-size:2.2rem;font-weight:800;margin-bottom:4px}
.summary-hero .hero-sub{font-size:1rem;color:rgba(255,255,255,0.75)}

.kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;padding:28px 32px;background:#f8f9fa}
.kpi-card{background:#fff;border-radius:14px;padding:24px 20px;text-align:center;
  box-shadow:0 2px 12px rgba(0,0,0,0.07);position:relative;overflow:hidden}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px}
.kpi-card.total::before{background:linear-gradient(90deg,#1a1a2e,#2c3e50)}
.kpi-card.fl::before{background:linear-gradient(90deg,#1a5276,#2980b9)}
.kpi-card.op::before{background:linear-gradient(90deg,#1e8449,#27ae60)}
.kpi-card.pl::before{background:linear-gradient(90deg,#7d6608,#f1c40f)}
.kpi-num{font-size:3rem;font-weight:800;line-height:1}
.kpi-card.total .kpi-num{color:#1a1a2e}
.kpi-card.fl .kpi-num{color:#1a5276}
.kpi-card.op .kpi-num{color:#1e8449}
.kpi-card.pl .kpi-num{color:#7d6608}
.kpi-label{font-size:0.9rem;color:#5d6d7e;margin-top:8px;font-weight:600}
.kpi-desc{font-size:0.78rem;color:#95a5a6;margin-top:4px}
.kpi-pct{font-size:0.82rem;font-weight:700;margin-top:6px;padding:3px 10px;border-radius:20px;display:inline-block}
.kpi-card.fl .kpi-pct{background:#d6eaf8;color:#1a5276}
.kpi-card.op .kpi-pct{background:#d5f5e3;color:#1e8449}
.kpi-card.pl .kpi-pct{background:#fef9e7;color:#7d6608}


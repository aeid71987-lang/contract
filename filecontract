.sico{font-size:1rem;color:#95a5a6}
.sinput{border:none;outline:none;font-family:inherit;font-size:0.9rem;color:#1a1a2e;width:100%;background:transparent;direction:rtl}
.fwrap{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.flbl{font-size:0.82rem;color:#5d6d7e;font-weight:600}
.fbtn{background:#fff;border:1.5px solid #dde3ed;color:#5d6d7e;
